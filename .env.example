# ---- Required ----
# Your Firecrawl API key (https://www.firecrawl.dev/app). This is the ONLY required input.
FIRECRAWL_API_KEY=fc-...

# ---- Optional: LLM-enhanced probe expansion ----
# The tool runs fully without these — deterministic expansion is the default.
# Set --llm on the CLI to turn on LLM expansion; it reads the vars below.
#
# Provider: "ollama" (local, default) or "anthropic".
LLM_PROVIDER=ollama
# Ollama default. For Anthropic use https://api.anthropic.com
LLM_BASE_URL=http://localhost:11434
# Model id. Ollama e.g. "llama3.2:3b"; Anthropic e.g. "claude-opus-4-8".
LLM_MODEL=llama3.2:3b

# ---- Optional: evaluation (npm run eval:rank) ----
# The ranking eval uses an LLM-as-judge. It prefers Anthropic Claude when a key
# is present (a capable judge matters — a weak one inverts the result), and only
# falls back to the local model otherwise. Used OFF the serving path.
# Set this and `npm run eval:rank` judges with claude-opus-4-8.
ANTHROPIC_API_KEY=
# Override the judge model (default claude-opus-4-8).
JUDGE_MODEL=
