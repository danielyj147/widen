# Required: your Firecrawl API key (the only required input).
FIRECRAWL_API_KEY=fc-...

# Optional: LLM query expansion (--llm) and the eval judge (npm run eval:rank).
# Expansion defaults to local Ollama; the judge uses Anthropic if a key is set.
LLM_PROVIDER=ollama                     # ollama (local) | anthropic
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
ANTHROPIC_API_KEY=                      # enables the Claude eval judge
JUDGE_MODEL=                            # override judge model (default claude-opus-4-8)
