# ---- Required ----
# Your Firecrawl API key (https://www.firecrawl.dev/app). This is the ONLY required input.
FIRECRAWL_API_KEY=fc-...

# ---- Optional: LLM-enhanced probe expansion ----
# The tool runs fully without these — deterministic expansion is the default.
# Set --llm on the CLI to turn on LLM expansion; it reads the vars below.
#
# Provider: "ollama" (local, default) or "anthropic".
LLM_PROVIDER=ollama
# Ollama default. For Anthropic use https://api.anthropic.com
LLM_BASE_URL=http://localhost:11434
# Model id. Ollama e.g. "llama3.2:3b"; Anthropic e.g. "claude-sonnet-4-6".
LLM_MODEL=llama3.2:3b
# Only needed when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
